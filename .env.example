DATABASE_URL="postgresql://devsync:devsync@localhost:5432/devsync?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_ACCESS_SECRET="replace-this-access-secret"
JWT_REFRESH_SECRET="replace-this-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=4000

# Object storage (S3-compatible, MinIO by default — see docker-compose.yml)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="devsync"
S3_ACCESS_KEY_ID="devsync"
S3_SECRET_ACCESS_KEY="devsync123"
S3_FORCE_PATH_STYLE="true"

